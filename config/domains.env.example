# Domain configuration for cert-auto
# Copy this file to domains.env and fill in your values

# Primary domain for certificate (legacy single-domain mode)
CERT_DOMAIN=static.zerocmf.com

# Space-separated SAN domains for one certificate.
# CERT_DOMAINS="codecloud.ltd www.codecloud.ltd"

# Aliyun profile used by aic for DNS-01 and CAS upload.
# ALIYUN_PROFILE=enterprise

# Certificate name prefix in Aliyun CAS (optional, defaults to {domain}-{date})
# CERT_NAME_PREFIX=static-zerocmf-com

# Optional: update Function Compute custom domains after uploading to CAS.
# FC_CUSTOM_DOMAINS="codecloud.ltd www.codecloud.ltd"
# ALIYUN_FC_REGION=cn-shanghai
